# The frontend auto-derives the backend URL from the page address
# (window.location), so the same build works on both:
#   http://localhost:3000   -> http://localhost:4000
#   https://<lan-ip>:3000   -> https://<lan-ip>:4000
# You normally do NOT need to set anything here.

# Override the backend host only if it runs somewhere else:
# NEXT_PUBLIC_API_URL=https://192.168.1.42:4000

# Override the backend port (default 4000):
# NEXT_PUBLIC_API_PORT=4000

# Google Sign-In — OAuth 2.0 Web application Client ID (same one set as
# GOOGLE_CLIENT_ID in the backend). Leave empty to hide the Google button.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
