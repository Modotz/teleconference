# Server
PORT=4000
NODE_ENV=development

# Allowed CORS origins. "*" = any origin (fine for dev). In production
# use an explicit comma-separated list, e.g. https://app.example.com
CLIENT_ORIGIN=*

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/teleconference?schema=public"

# JWT (user login tokens)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google Sign-In — OAuth 2.0 *Web application* Client ID from
# https://console.cloud.google.com/apis/credentials  (must be the SAME id the
# frontend uses in NEXT_PUBLIC_GOOGLE_CLIENT_ID). Leave empty to disable.
GOOGLE_CLIENT_ID=

# Public URL of the FRONTEND (used to build verification / reset links in emails).
APP_URL=http://localhost:3000

# Email (SMTP) for verification + password reset. If SMTP_HOST is empty, emails
# are printed to the server console instead (handy for local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Teleconference <no-reply@example.com>"

# Voice Call API — secret for signing third-party guest access tokens.
# Falls back to JWT_SECRET if unset.
CALL_TOKEN_SECRET=change-this-to-another-long-random-secret
CALL_TOKEN_TTL=15m

# Mediasoup
# Listen on all interfaces so phones on LAN can reach it
MEDIASOUP_LISTEN_IP=0.0.0.0
# Comma-separated announced IPs. Keep 127.0.0.1 for localhost dev; add your
# LAN IP for phone/LAN testing. Both are advertised at once.
# scripts\setup-lan.ps1 fills in the LAN IP automatically.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=40100

# HTTPS (used only by `npm run dev:https`). Generate certs with
# scripts/generate-certs.ps1. `npm run dev` always runs plain HTTP.
SSL_CERT_PATH=../certs/cert.pem
SSL_KEY_PATH=../certs/key.pem
